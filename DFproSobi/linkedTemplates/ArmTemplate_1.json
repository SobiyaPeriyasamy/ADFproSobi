{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "DFproSobi"
		},
		"schedule_properties_schedule_parameters_schema": {
			"type": "string",
			"defaultValue": "source"
		},
		"schedule_properties_schedule_parameters_table": {
			"type": "string",
			"defaultValue": "Orders"
		},
		"schedule_properties_schedule_parameters_backdate": {
			"type": "string",
			"defaultValue": "\"\""
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/schedule')]",
			"type": "Microsoft.DataFactory/factories/triggers",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"runtimeState": "Started",
				"pipelines": [
					{
						"pipelineReference": {
							"referenceName": "schedule",
							"type": "PipelineReference"
						},
						"parameters": {
							"schema": "[parameters('schedule_properties_schedule_parameters_schema')]",
							"table": "[parameters('schedule_properties_schedule_parameters_table')]",
							"backdate": "[parameters('schedule_properties_schedule_parameters_backdate')]"
						}
					}
				],
				"type": "ScheduleTrigger",
				"typeProperties": {
					"recurrence": {
						"frequency": "Day",
						"interval": 1,
						"startTime": "2026-04-14T23:00:00",
						"timeZone": "India Standard Time"
					}
				}
			},
			"dependsOn": []
		}
	]
}