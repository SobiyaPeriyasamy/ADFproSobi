									"typeProperties": {
										"source": {
											"type": "AzureSqlSource",
											"sqlReaderQuery": {
												"value": "SELECT *\nFROM @{pipeline().parameters.schems}.@{pipeline().parameters.table}\nWHERE LAST_UPDATED > '@{if(empty(pipeline().parameters.back_date),\n                               activity('Lookup1').output.firstRow.cdc_timestamp,\n                               pipeline().parameters.back_date)} '\n",
												"type": "Expression"
											},
											"queryTimeout": "02:00:00",
											"partitionOption": "None"
										},
										"sink": {
											"type": "JsonSink",
											"storeSettings": {
